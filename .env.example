# API Keys for AI Engines
# Paste your Groq API key here (recommended)
GROQ_API_KEY=

# Or paste your Google Gemini API key here
GEMINI_API_KEY=

# Backend Configurations
PORT=8000
DATABASE_URL=sqlite:////app/data/lmls.db

# Google OAuth — Optional: enables real Calendar sync & Gmail drafts
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/oauth/google/callback
